@page
@model AccessDeniedModel
@{
    ViewData["Title"] = "Доступ запрещен";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="section-card text-center">
            <div class="mb-3" style="font-size: 52px;">⛔</div>
            <h2 class="mb-2">Доступ запрещен</h2>
            <p class="text-muted mb-4">
                У вас недостаточно прав для выполнения этого действия или просмотра этой страницы.
            </p>

            <div class="d-flex justify-content-center gap-2 flex-wrap">
                <a asp-page="/Index" class="btn btn-primary">На главную</a>
                <button type="button" class="btn btn-outline-secondary" onclick="history.back()">
                    Назад
                </button>
            </div>
        </div>
    </div>
</div>