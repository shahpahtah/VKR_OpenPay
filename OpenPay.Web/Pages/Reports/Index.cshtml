@page
@model OpenPay.Web.Pages.Reports.IndexModel
@{
    ViewData["Title"] = "Отчетность";
}

<h2 class="mb-3">Отчетность по платежам</h2>

<form method="get" class="row g-3 mb-4">
    <div class="col-md-3">
        <label asp-for="DateFrom" class="form-label">Дата платежа с</label>
        
        <input asp-for="DateFrom" type="date" class="form-control" />
    </div>
    <div class="col-md-3">
        <label asp-for="DateTo" class="form-label">Дата платежа по</label>
        <input asp-for="DateTo" type="date" class="form-control" />
    </div>
    <div class="col-md-3 d-flex align-items-end">
        <button type="submit" class="btn btn-primary">Сформировать</button>
    </div>
</form>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-primary">
            <div class="card-body">
                <h6 class="card-title">Всего платежей</h6>
                <div class="fs-4">@Model.Report.TotalPaymentsCount</div>
                <div class="text-muted">@Model.Report.TotalPaymentsAmount.ToString("N2")</div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-success">
            <div class="card-body">
                <h6 class="card-title">Исполнено</h6>
                <div class="fs-4">@Model.Report.ExecutedPaymentsCount</div>
                <div class="text-muted">@Model.Report.ExecutedPaymentsAmount.ToString("N2")</div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-warning">
            <div class="card-body">
                <h6 class="card-title">На согласовании</h6>
                <div class="fs-4">@Model.Report.PendingApprovalCount</div>
                <div class="text-muted">@Model.Report.PendingApprovalAmount.ToString("N2")</div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-danger">
            <div class="card-body">
                <h6 class="card-title">Ошибки</h6>
                <div class="fs-4">@Model.Report.ErrorPaymentsCount</div>
                <div class="text-muted">@Model.Report.ErrorPaymentsAmount.ToString("N2")</div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">
        Сводка по статусам
    </div>
    <div class="card-body">
        @if (Model.Report.StatusSummary.Count == 0)
        {
            <div class="text-muted">Данные отсутствуют.</div>
        }
        else
        {
            <table class="table table-sm table-bordered mb-0">
                <thead>
                    <tr>
                        <th>Статус</th>
                        <th>Количество</th>
                        <th>Сумма</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Report.StatusSummary)
                    {
                        <tr>
                            <td>@item.Status</td>
                            <td>@item.Count</td>
                            <td>@item.TotalAmount.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<div class="card">
    <div class="card-header">
        Платежи за выбранный период
    </div>
    <div class="card-body">
        @if (Model.Report.Items.Count == 0)
        {
            <div class="text-muted">Платежи не найдены.</div>
        }
        else
        {
            <table class="table table-striped table-bordered">
                <thead>
                    <tr>
                        <th>Номер</th>
                        <th>Дата создания</th>
                        <th>Дата платежа</th>
                        <th>Контрагент</th>
                        <th>Сумма</th>
                        <th>Статус</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Report.Items)
                    {
                        <tr>
                            <td>@item.DocumentNumber</td>
                            <td>@item.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@(item.PaymentDate?.ToString("dd.MM.yyyy") ?? "-")</td>
                            <td>@item.CounterpartyName</td>
                            <td>@item.Amount.ToString("N2") @item.Currency</td>
                            <td>@item.Status</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>