@page
@model OpenPay.Web.Pages.Accounts.IndexModel
@{
    ViewData["Title"] = "Банковские счета";
}

<div class="page-actions">
    <div>
        <h2 class="mb-1">Банковские счета организации</h2>
        <div class="text-muted">Счета, валюты, подразделения и привязка к банковским адаптерам</div>
    </div>
    <a asp-page="Create" class="btn btn-primary">Добавить счет</a>
</div>

<div class="section-card mb-4">
    <form method="get" class="row g-3 align-items-end">
        <div class="col-md-6">
            <label asp-for="Search" class="form-label">Поиск</label>
            <input asp-for="Search" class="form-control" placeholder="Банк, БИК, счет, подразделение" />
        </div>
        <div class="col-md-3 d-flex align-items-center">
            <div class="form-check">
                <input asp-for="ShowInactive" class="form-check-input" />
                <label asp-for="ShowInactive" class="form-check-label">Показывать неактивные</label>
            </div>
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-primary flex-grow-1">Найти</button>
            <a asp-page="Index" class="btn btn-outline-secondary">Сбросить</a>
        </div>
    </form>
</div>

<div class="section-card">
<div class="table-responsive">
<table class="table table-hover align-middle mb-0">
    <thead>
        <tr>
            <th>Банк</th>
            <th>БИК</th>
            <th>Номер счета</th>
            <th>Валюта</th>
            <th>Ответственное подразделение</th>
            <th>Подключение</th>
            <th>Статус</th>
            <th style="width: 220px;">Действия</th>
        </tr>
    </thead>
    <tbody>
    @if (Model.Items.Count == 0)
    {
        <tr>
            <td colspan="8" class="text-center text-muted py-4">Записи не найдены</td>
        </tr>
    }
    else
    {
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.BankName</td>
                <td>@item.Bic</td>
                <td>@item.AccountNumber</td>
                <td>@item.Currency</td>
                <td>@item.ResponsibleUnit</td>
                <td>@item.BankConnectionDisplay</td>
                <td>
                    @if (item.IsActive)
                    {
                        <span class="badge-soft badge-executed">Активен</span>
                    }
                    else
                    {
                        <span class="badge-soft badge-draft">Неактивен</span>
                    }
                </td>
                <td>
                    <a asp-page="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Редактировать</a>

                    @if (item.IsActive)
                    {
                        <form method="post" asp-page-handler="Deactivate" asp-route-id="@item.Id" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                    onclick="return confirm('Деактивировать счет?');">
                                Деактивировать
                            </button>
                        </form>
                    }
                </td>
            </tr>
        }
    }
    </tbody>
</table>
</div>
</div>
