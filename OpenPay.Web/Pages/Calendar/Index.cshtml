@page
@model OpenPay.Web.Pages.Calendar.IndexModel
@{
    ViewData["Title"] = "Календарь";
}

<div class="page-actions">
    <div>
        <h2 class="mb-1">Платежный календарь</h2>
        <div class="text-muted">Планирование и просмотр платежей по датам</div>
    </div>
</div>

<div class="section-card mb-4">
    <form method="get" class="row g-3 align-items-end">
        <div class="col-lg-3">
            <label asp-for="DateFrom" class="form-label">Дата с</label>
            <input asp-for="DateFrom" type="date" class="form-control" />
        </div>

        <div class="col-lg-3">
            <label asp-for="DateTo" class="form-label">Дата по</label>
            <input asp-for="DateTo" type="date" class="form-control" />
        </div>

        <div class="col-lg-6 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Показать</button>
            <a asp-page="Index" class="btn btn-outline-secondary">Сбросить</a>
        </div>
    </form>
</div>

@if (Model.Days.Count == 0)
{
    <div class="section-card">
        <div class="empty-state">
            <h5 class="mb-2">Нет запланированных платежей</h5>
            <div>За выбранный период документы не найдены.</div>
        </div>
    </div>
}
else
{
    <div class="d-flex flex-column gap-4">
        @foreach (var day in Model.Days)
        {
            <div class="section-card">
                <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                    <div>
                        <h5 class="mb-1">@day.Date.ToString("dd.MM.yyyy")</h5>
                        <div class="text-muted small">Платежей на дату: @day.Payments.Count</div>
                    </div>

                    <div class="text-muted small">
                        Общая сумма:
                        <span class="fw-semibold">
                            @day.Payments.Sum(x => x.Amount).ToString("N2")
                        </span>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Номер</th>
                                <th>Контрагент</th>
                                <th>Сумма</th>
                                <th>Статус</th>
                                <th style="width: 130px;">Действие</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var payment in day.Payments)
                            {
                                <tr>
                                    <td class="fw-semibold">@payment.DocumentNumber</td>
                                    <td>@payment.CounterpartyName</td>
                                    <td class="fw-semibold">@payment.Amount.ToString("N2") @payment.Currency</td>
                                    <td>
                                        <span class="@UiText.PaymentStatusCss(payment.Status)">
                                            @UiText.PaymentStatusText(payment.Status)
                                        </span>
                                    </td>
                                    <td>
                                        <a asp-page="/Payments/Edit"
                                           asp-route-id="@payment.Id"
                                           class="btn btn-sm btn-outline-primary">
                                            Открыть
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
}