@page
@model OpenPay.Web.Pages.Payments.IndexModel
@{
    ViewData["Title"] = "Платежи";
}


<div class="page-actions">
    <div>
        <h2 class="mb-1">Платежные поручения</h2>
        <div class="text-muted">Управление платежами, поиск и контроль статусов</div>
    </div>

    <div class="d-flex gap-2">
        <a asp-page="Create" class="btn btn-primary">Создать платеж</a>
        <a asp-page="Import" class="btn btn-outline-secondary">Импорт CSV</a>
    </div>
</div>

<div class="section-card mb-4">
    <form method="get" class="row g-3 align-items-end">
        <div class="col-lg-8">
            <label asp-for="Search" class="form-label">Поиск</label>
            <input asp-for="Search" class="form-control" placeholder="Номер, назначение, контрагент" />
        </div>

        <div class="col-lg-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary flex-grow-1">Найти</button>
            <a asp-page="Index" class="btn btn-outline-secondary">Сбросить</a>
        </div>
    </form>
</div>

<div class="section-card">
    @if (Model.Items.Count == 0)
    {
        <div class="empty-state">
            <h5 class="mb-2">Платежи не найдены</h5>
            <div class="mb-3">Создайте первый платеж или измените параметры поиска.</div>
            <a asp-page="Create" class="btn btn-primary">Создать платеж</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Номер</th>
                        <th>Дата создания</th>
                        <th>Дата платежа</th>
                        <th>Контрагент</th>
                        <th>Счет организации</th>
                        <th>Тип расхода</th>
                        <th>Сумма</th>
                        <th>Статус</th>
                        <th style="width: 280px;">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="fw-semibold">@item.DocumentNumber</td>
                            <td>@item.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@(item.PaymentDate?.ToString("dd.MM.yyyy") ?? "-")</td>
                            <td>@item.CounterpartyName</td>
                            <td>@item.OrganizationAccountDisplay</td>
                            <td>@(string.IsNullOrWhiteSpace(item.ExpenseType) ? "—" : item.ExpenseType)</td>
                            <td class="fw-semibold">@item.Amount.ToString("N2") @item.Currency</td>
                            <td>
                                <span class="@UiText.PaymentStatusCss(item.Status)">
                                    @UiText.PaymentStatusText(item.Status)
                                </span>
                            </td>
                            <td>
                                <div class="d-flex flex-wrap gap-2">
                                    @if (item.Status == "Draft" || item.Status == "Rework")
                                    {
                                        <a asp-page="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                            Редактировать
                                        </a>

                                        <form method="post" asp-page-handler="SubmitForApproval" asp-route-id="@item.Id" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-primary">
                                                На согласование
                                            </button>
                                        </form>
                                    }
                                    else if (item.Status == "Approved" || item.Status == "ReadyToSend")
                                    {
                                        <a asp-page="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">
                                            Открыть
                                        </a>

                                        <form method="post" asp-page-handler="SendToBank" asp-route-id="@item.Id" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-success">
                                                Подписать и отправить
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <a asp-page="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">
                                            Открыть
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
