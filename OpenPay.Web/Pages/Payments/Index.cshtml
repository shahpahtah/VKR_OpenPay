@page
@model OpenPay.Web.Pages.Payments.IndexModel
@{
    ViewData["Title"] = "Платежные поручения";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Платежные поручения</h2>
    <a asp-page="Create" class="btn btn-primary">Создать платеж</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-8">
        <input asp-for="Search" class="form-control" placeholder="Поиск по номеру, назначению, контрагенту" />
    </div>
    <div class="col-md-4">
        <button type="submit" class="btn btn-outline-secondary">Найти</button>
    </div>
</form>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Номер</th>
            <th>Дата создания</th>
            <th>Дата платежа</th>
            <th>Контрагент</th>
            <th>Счет организации</th>
            <th>Сумма</th>
            <th>Статус</th>
            <th style="width: 300px;">Действия</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr>
                <td colspan="8" class="text-center">Платежи не найдены</td>
            </tr>
        }
        else
        {
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.DocumentNumber</td>
                    <td>@item.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@(item.PaymentDate?.ToString("dd.MM.yyyy") ?? "-")</td>
                    <td>@item.CounterpartyName</td>
                    <td>@item.OrganizationAccountDisplay</td>
                    <td>@item.Amount.ToString("N2") @item.Currency</td>
                    <td>
                        @if (item.Status == "Draft")
                        {
                            <span class="badge bg-secondary">@item.Status</span>
                        }
                        else if (item.Status == "PendingApproval")
                        {
                            <span class="badge bg-warning text-dark">@item.Status</span>
                        }
                        else if (item.Status == "Approved")
                        {
                            <span class="badge bg-success">@item.Status</span>
                        }
                        else if (item.Status == "Rejected")
                        {
                            <span class="badge bg-danger">@item.Status</span>
                        }
                        else if (item.Status == "Rework")
                        {
                            <span class="badge bg-info text-dark">@item.Status</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">@item.Status</span>
                        }
                    </td>
                    <td>
                        @if (item.Status == "Draft" || item.Status == "Rework")
                        {
                            <a asp-page="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Редактировать</a>

                            <form method="post" asp-page-handler="SubmitForApproval" asp-route-id="@item.Id" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-success">
                                    На согласование
                                </button>
                            </form>
                        }
                        else if (item.Status == "Approved")
                        {
                            <a asp-page="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Просмотр</a>

                            <form method="post" asp-page-handler="SendToBank" asp-route-id="@item.Id" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-success">
                                    Отправить в банк
                                </button>
                            </form>
                        }
                        else if (item.Status == "Sent")
                        {
                            <a asp-page="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Просмотр</a>
                        }
                        else
                        {
                            <a asp-page="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Просмотр</a>
                        }
                    </td>
                </tr>
            }
        }
    </tbody>
</table>