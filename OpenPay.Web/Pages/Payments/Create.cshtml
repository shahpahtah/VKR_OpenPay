@page
@model OpenPay.Web.Pages.Payments.CreateModel
@using System.Text.Json
@{
    ViewData["Title"] = "Создание платежа";
}

<div class="page-actions">
    <div>
        <h2 class="mb-1">Создание платежного поручения</h2>
        <div class="text-muted">Заполните реквизиты документа и сохраните его как черновик</div>
    </div>

    <div>
        <a asp-page="Index" class="btn btn-outline-secondary">Назад к списку</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="section-card">
            <form method="post">
                <input asp-for="Item.CounterpartyId" type="hidden" id="counterpartyId" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="Item.DocumentNumber" class="form-label"></label>
                        <input asp-for="Item.DocumentNumber" class="form-control" placeholder="Можно оставить пустым" />
                        <span asp-validation-for="Item.DocumentNumber" class="text-danger"></span>
                        <div class="form-text">Если оставить пустым, номер будет сгенерирован автоматически.</div>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Item.PaymentDate" class="form-label"></label>
                        <input asp-for="Item.PaymentDate" type="date" class="form-control" />
                        <span asp-validation-for="Item.PaymentDate" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Item.Currency" class="form-label"></label>
                        <input asp-for="Item.Currency" class="form-control" placeholder="RUB" />
                        <span asp-validation-for="Item.Currency" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Item.ExpenseType" class="form-label"></label>
                        <input asp-for="Item.ExpenseType" class="form-control" placeholder="Поставщики, аренда, налоги" />
                        <span asp-validation-for="Item.ExpenseType" class="text-danger"></span>
                    </div>

                    <div class="col-md-12 position-relative">
                        <label class="form-label">Контрагент</label>
                        <input type="text"
                               id="counterpartySearch"
                               class="form-control"
                               placeholder="Введите ИНН или название контрагента"
                               autocomplete="off" />
                        <div id="counterpartyResults"
                             class="list-group position-absolute w-100 shadow-sm d-none"
                             style="z-index: 1000; max-height: 260px; overflow-y: auto;"></div>
                        <span asp-validation-for="Item.CounterpartyId" class="text-danger"></span>
                    </div>

                    <div class="col-md-12">
                        <div id="counterpartyPreview" class="p-3 rounded-3 border bg-light d-none">
                            <div><strong>Контрагент:</strong> <span id="previewName"></span></div>
                            <div><strong>ИНН:</strong> <span id="previewInn"></span></div>
                        </div>
                    </div>

                    <div class="col-md-8">
                        <label asp-for="Item.OrganizationBankAccountId" class="form-label"></label>
                        <select asp-for="Item.OrganizationBankAccountId" asp-items="Model.AccountOptions" class="form-select">
                            <option value="">-- выберите счет организации --</option>
                        </select>
                        <span asp-validation-for="Item.OrganizationBankAccountId" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Item.Amount" class="form-label"></label>
                        <input asp-for="Item.Amount" class="form-control" />
                        <span asp-validation-for="Item.Amount" class="text-danger"></span>
                    </div>

                    <div class="col-md-12">
                        <label asp-for="Item.Purpose" class="form-label"></label>
                        <input asp-for="Item.Purpose" class="form-control" placeholder="Назначение платежа" />
                        <span asp-validation-for="Item.Purpose" class="text-danger"></span>
                    </div>
                </div>

                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Сохранить как черновик</button>
                    <a asp-page="Index" class="btn btn-outline-secondary">Отмена</a>
                </div>
            </form>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="section-card h-100">
            <h5 class="mb-3">Подсказки</h5>

            <div class="d-flex flex-column gap-3 text-muted">
                <div>• Сначала создайте контрагента и счет организации, если их еще нет в системе.</div>
                <div>• После сохранения платеж появится в статусе <strong>Черновик</strong>.</div>
                <div>• Маршрут согласования подберется автоматически по сумме, типу расхода и подразделению счета.</div>
                <div>• Из списка платежей черновик можно отправить на согласование.</div>
                <div>• Номер платежа можно оставить пустым — система сгенерирует его автоматически.</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const counterparties = @Html.Raw(JsonSerializer.Serialize(
                    Model.Counterparties.Select(x => new
                    {
                            id = x.Id,
                            inn = x.Inn,
                            name = x.FullName
                    })
            ));

        const searchInput = document.getElementById('counterpartySearch');
        const results = document.getElementById('counterpartyResults');
        const hiddenId = document.getElementById('counterpartyId');
        const preview = document.getElementById('counterpartyPreview');
        const previewName = document.getElementById('previewName');
        const previewInn = document.getElementById('previewInn');

        function renderResults(items) {
            results.innerHTML = '';

            if (!items.length) {
                results.classList.add('d-none');
                return;
            }

            for (const item of items) {
                const button = document.createElement('button');
                button.type = 'button';
                button.className = 'list-group-item list-group-item-action';
                button.innerHTML = `<div class="fw-semibold">${item.name}</div><div class="small text-muted">${item.inn}</div>`;

                button.addEventListener('click', () => {
                    hiddenId.value = item.id;
                    searchInput.value = `${item.name} (${item.inn})`;
                    previewName.textContent = item.name;
                    previewInn.textContent = item.inn;
                    preview.classList.remove('d-none');
                    results.classList.add('d-none');
                });

                results.appendChild(button);
            }

            results.classList.remove('d-none');
        }

        function filterCounterparties() {
            const term = (searchInput.value || '').toLowerCase().trim();

            if (!term) {
                results.classList.add('d-none');
                return;
            }

            const filtered = counterparties
                .filter(x =>
                    (x.name || '').toLowerCase().includes(term) ||
                    (x.inn || '').toLowerCase().includes(term))
                .slice(0, 20);

            renderResults(filtered);
        }

        searchInput.addEventListener('input', () => {
            hiddenId.value = '';
            preview.classList.add('d-none');
            filterCounterparties();
        });

        document.addEventListener('click', (e) => {
            if (!results.contains(e.target) && e.target !== searchInput) {
                results.classList.add('d-none');
            }
        });
    </script>
}
