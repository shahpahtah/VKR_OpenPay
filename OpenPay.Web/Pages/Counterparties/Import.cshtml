@page
@model OpenPay.Web.Pages.Counterparties.ImportModel
@{
    ViewData["Title"] = "Импорт контрагентов";
}

<div class="page-actions">
    <div>
        <h2 class="mb-1">Импорт контрагентов из CSV</h2>
        <div class="text-muted">Загрузка справочника контрагентов в кодировке UTF-8</div>
    </div>

    <div>
        <a asp-page="Index" class="btn btn-outline-secondary">Назад к списку</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="section-card">
            <form method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="UploadFile" class="form-label">CSV-файл</label>
                    <input asp-for="UploadFile" type="file" class="form-control" accept=".csv" />
                </div>

                <div class="small text-muted mb-3">
                    Ожидаемые колонки: <strong>INN</strong>, <strong>Name</strong> или <strong>FullName</strong>,
                    <strong>KPP</strong>, <strong>BIC</strong>, <strong>AccountNumber</strong>,
                    <strong>CorrespondentAccount</strong>.
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Импортировать</button>
                    <a asp-page="Index" class="btn btn-outline-secondary">Отмена</a>
                </div>
            </form>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="section-card h-100">
            <h5 class="mb-3">Пример CSV</h5>

            <pre class="small mb-0">INN;Name;KPP;BIC;AccountNumber;CorrespondentAccount
7701234567;ООО "Ромашка";770101001;044525225;40702810000000000001;30101810400000000225
780123456789;ООО "Вектор";780101001;044525225;40702810000000000002;30101810400000000225</pre>
        </div>
    </div>
</div>

@if (Model.Result != null)
{
    <div class="section-card mt-4">
        <h5 class="mb-3">Результат импорта</h5>

        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="kpi-card">
                    <div class="kpi-label">Всего строк</div>
                    <div class="kpi-value">@Model.Result.TotalRows</div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="kpi-card">
                    <div class="kpi-label">Успешно импортировано</div>
                    <div class="kpi-value">@Model.Result.ImportedRows</div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="kpi-card">
                    <div class="kpi-label">С ошибками</div>
                    <div class="kpi-value">@Model.Result.ErrorRows</div>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Строка</th>
                        <th>INN</th>
                        <th>Наименование</th>
                        <th>Результат</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Result.Items)
                    {
                        <tr>
                            <td>@item.RowNumber</td>
                            <td>@item.Inn</td>
                            <td>@item.FullName</td>
                            <td>
                                @if (item.IsImported)
                                {
                                    <span class="badge bg-success">@item.Message</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">@item.Message</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
