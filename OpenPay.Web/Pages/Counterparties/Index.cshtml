@page
@model OpenPay.Web.Pages.Counterparties.IndexModel
@{
    ViewData["Title"] = "Контрагенты";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Контрагенты</h2>

    <div class="d-flex gap-2">
        <a asp-page="Create" class="btn btn-primary">Добавить контрагента</a>
        <a asp-page="Import" class="btn btn-outline-secondary">Импорт CSV</a>
    </div>
</div>
<form method="get" class="row g-2 mb-3">
    <div class="col-md-6">
        <input asp-for="Search" class="form-control" placeholder="Поиск по ИНН или наименованию" />
    </div>
    <div class="col-md-3 d-flex align-items-center">
        <div class="form-check">
            <input asp-for="ShowInactive" class="form-check-input" />
            <label asp-for="ShowInactive" class="form-check-label">Показывать неактивных</label>
        </div>
    </div>
    <div class="col-md-3">
        <button type="submit" class="btn btn-outline-secondary">Найти</button>
    </div>
</form>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>ИНН</th>
            <th>Наименование</th>
            <th>БИК</th>
            <th>Расчетный счет</th>
            <th>Статус</th>
            <th style="width: 220px;">Действия</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr>
                <td colspan="6" class="text-center">Записи не найдены</td>
            </tr>
        }
        else
        {
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.Inn</td>
                    <td>@item.FullName</td>
                    <td>@item.Bic</td>
                    <td>@item.AccountNumber</td>
                    <td>
                        @if (item.IsActive)
                        {
                            <span class="badge bg-success">Активен</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Неактивен</span>
                        }
                    </td>
                    <td>
                        <a asp-page="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Редактировать</a>

                        @if (item.IsActive)
                        {
                            <form method="post" asp-page-handler="Deactivate" asp-route-id="@item.Id" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                        onclick="return confirm('Деактивировать контрагента?');">
                                    Деактивировать
                                </button>
                            </form>
                        }
                    </td>
                </tr>
            }
        }
    </tbody>
</table>