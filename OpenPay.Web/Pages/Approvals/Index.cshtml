@page
@model OpenPay.Web.Pages.Approvals.IndexModel
@{
    ViewData["Title"] = "Согласование платежей";
}

<h2 class="mb-3">Платежи на согласовании</h2>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Номер</th>
            <th>Дата создания</th>
            <th>Дата платежа</th>
            <th>Контрагент</th>
            <th>Сумма</th>
            <th>Назначение</th>
            <th style="width: 130px;">Действия</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr>
                <td colspan="7" class="text-center">Нет платежей на согласовании</td>
            </tr>
        }
        else
        {
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.DocumentNumber</td>
                    <td>@item.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@(item.PaymentDate?.ToString("dd.MM.yyyy") ?? "-")</td>
                    <td>@item.CounterpartyName</td>
                    <td>@item.Amount.ToString("N2") @item.Currency</td>
                    <td>@item.Purpose</td>
                    <td>
                        <a asp-page="Review" asp-route-id="@item.PaymentOrderId" class="btn btn-sm btn-outline-primary">
                            Рассмотреть
                        </a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>