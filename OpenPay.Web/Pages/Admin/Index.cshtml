@page
@model OpenPay.Web.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Журнал аудита";
}

<h2 class="mb-3">Журнал аудита</h2>

<table class="table table-striped table-bordered table-sm">
    <thead>
        <tr>
            <th>Дата</th>
            <th>Событие</th>
            <th>Пользователь</th>
            <th>Объект</th>
            <th>Описание</th>
            <th>IP</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr>
                <td colspan="6" class="text-center">Записи аудита отсутствуют</td>
            </tr>
        }
        else
        {
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@item.EventType</td>
                    <td>@item.UserName</td>
                    <td>@(string.IsNullOrWhiteSpace(item.ObjectType) ? "-" : $"{item.ObjectType}: {item.ObjectId}")</td>
                    <td>@item.Description</td>
                    <td>@(string.IsNullOrWhiteSpace(item.IpAddress) ? "-" : item.IpAddress)</td>
                </tr>
            }
        }
    </tbody>
</table>