@page
@model OpenPay.Web.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Аудит";
}

<div class="page-actions">
    <div>
        <h2 class="mb-1">Журнал аудита</h2>
        <div class="text-muted">История действий пользователей и изменений в системе</div>
    </div>
</div>

<div class="section-card mb-4">
    <form method="get" class="row g-3 align-items-end">
        <div class="col-lg-2">
            <label asp-for="DateFrom" class="form-label">С даты</label>
            <input asp-for="DateFrom" type="date" class="form-control" />
        </div>

        <div class="col-lg-2">
            <label asp-for="DateTo" class="form-label">По дату</label>
            <input asp-for="DateTo" type="date" class="form-control" />
        </div>

        <div class="col-lg-3">
            <label asp-for="UserQuery" class="form-label">Пользователь</label>
            <input asp-for="UserQuery" class="form-control" placeholder="ФИО или ID" />
        </div>

        <div class="col-lg-3">
            <label asp-for="EventType" class="form-label">Тип события</label>
            <select asp-for="EventType" asp-items="Model.EventTypeOptions" class="form-select"></select>
        </div>

        <div class="col-lg-2">
            <label asp-for="ObjectId" class="form-label">ObjectId / PaymentId</label>
            <input asp-for="ObjectId" class="form-control" placeholder="GUID или часть ID" />
        </div>

        <div class="col-12 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Применить</button>
            <a asp-page="Index" class="btn btn-outline-secondary">Сбросить</a>
        </div>
    </form>
</div>

<div class="section-card">
    @if (Model.Items.Count == 0)
    {
        <div class="empty-state">
            <h5 class="mb-2">Записи аудита не найдены</h5>
            <div>Попробуйте изменить параметры фильтра.</div>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Дата и время</th>
                        <th>Событие</th>
                        <th>Пользователь</th>
                        <th>Объект</th>
                        <th>Описание</th>
                        <th>IP</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="fw-semibold">
                                @item.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                            </td>
                            <td>
                                <span class="@UiText.AuditEventCss(item.EventType)">
                                    @UiText.AuditEventText(item.EventType)
                                </span>
                            </td>
                            <td>@item.UserName</td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(item.ObjectType) || !string.IsNullOrWhiteSpace(item.ObjectId))
                                {
                                    <div class="fw-semibold">@item.ObjectType</div>
                                    <div class="text-muted small">@item.ObjectId</div>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td style="min-width: 260px;">
                                @item.Description
                            </td>
                            <td>
                                @(string.IsNullOrWhiteSpace(item.IpAddress) ? "—" : item.IpAddress)
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>