@page
@model OpenPay.Web.Pages.Admin.Organizations.IndexModel
@{
    ViewData["Title"] = "Организации";
}

<div class="page-actions">
    <div>
        <h2 class="mb-1">Организации</h2>
        <div class="text-muted">Управление компаниями и их статусом в системе</div>
    </div>

    <div>
        <a asp-page="Create" class="btn btn-primary">Создать организацию</a>
    </div>
</div>

<div class="section-card">
    @if (Model.Items.Count == 0)
    {
        <div class="empty-state">
            <h5 class="mb-2">Организации не найдены</h5>
            <div class="mb-3">Создайте первую организацию для начала работы.</div>
            <a asp-page="Create" class="btn btn-primary">Создать организацию</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Название</th>
                        <th>ИНН</th>
                        <th>КПП</th>
                        <th>Статус</th>
                        <th style="width: 220px;">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="fw-semibold">@item.Name</td>
                            <td>@item.Inn</td>
                            <td>@item.Kpp</td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success">Активна</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Неактивна</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex flex-wrap gap-2">
                                    @if (item.IsActive)
                                    {
                                        <form method="post" asp-page-handler="Deactivate" asp-route-id="@item.Id" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                Деактивировать
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form method="post" asp-page-handler="Activate" asp-route-id="@item.Id" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-success">
                                                Активировать
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>