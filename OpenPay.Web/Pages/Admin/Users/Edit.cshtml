@page "{id}"
@model OpenPay.Web.Pages.Admin.Users.EditModel
@{
    ViewData["Title"] = "Редактирование сотрудника";
}

<div class="page-actions">
    <div>
        <h2 class="mb-1">Редактирование сотрудника</h2>
        <div class="text-muted">Изменение данных, роли и активности пользователя</div>
    </div>

    <a asp-page="Index" class="btn btn-outline-secondary">Назад к списку</a>
</div>

<div class="section-card">
    <form method="post">
        <input asp-for="Item.Id" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Item.FullName" class="form-label"></label>
                <input asp-for="Item.FullName" class="form-control" autocomplete="name" />
                <span asp-validation-for="Item.FullName" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Item.Email" class="form-label"></label>
                <input asp-for="Item.Email" class="form-control" autocomplete="email" />
                <span asp-validation-for="Item.Email" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Item.Role" class="form-label"></label>
                <select asp-for="Item.Role" asp-items="Model.RoleOptions" class="form-select"></select>
                <span asp-validation-for="Item.Role" class="text-danger"></span>
            </div>

            <div class="col-md-6 d-flex align-items-end">
                <div class="form-check">
                    <input asp-for="Item.IsActive" class="form-check-input" />
                    <label asp-for="Item.IsActive" class="form-check-label"></label>
                </div>
            </div>
        </div>

        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Сохранить изменения</button>
            <a asp-page="Index" class="btn btn-outline-secondary">Отмена</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
