@page
@model OpenPay.Web.Pages.Admin.Users.IndexModel
@{
    ViewData["Title"] = "Пользователи";
}

<div class="page-actions">
    <div>
        <h2 class="mb-1">Пользователи организации</h2>
        <div class="text-muted">Управление сотрудниками, ролями и доступом</div>
    </div>

    <div>
        <a asp-page="Create" class="btn btn-primary">Создать сотрудника</a>
    </div>
</div>

<div class="section-card">
    @if (Model.Items.Count == 0)
    {
        <div class="empty-state">
            <h5 class="mb-2">Пользователи не найдены</h5>
            <div class="mb-3">Создайте первого сотрудника для вашей организации.</div>
            <a asp-page="Create" class="btn btn-primary">Создать сотрудника</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>ФИО</th>
                        <th>Email</th>
                        <th>Роль</th>
                        <th>Организация</th>
                        <th>Статус</th>
                        <th style="width: 260px;">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="fw-semibold">@item.FullName</td>
                            <td>@item.Email</td>
                            <td>
                                <span class="badge-soft badge-approved">
                                    @UiText.RoleText(item.Role)
                                </span>
                            </td>
                            <td>@item.OrganizationName</td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success">Активен</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Неактивен</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex flex-wrap gap-2">
                                    <a asp-page="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                        Редактировать
                                    </a>

                                    @if (item.IsActive)
                                    {
                                        <form method="post" asp-page-handler="Deactivate" asp-route-id="@item.Id" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                Деактивировать
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form method="post" asp-page-handler="Activate" asp-route-id="@item.Id" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-success">
                                                Активировать
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>