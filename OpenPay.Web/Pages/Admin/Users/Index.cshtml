
@page
@model OpenPay.Web.Pages.Admin.Users.IndexModel
@{
    ViewData["Title"] = "Пользователи";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Пользователи организации</h2>
    <a asp-page="Create" class="btn btn-primary">Создать сотрудника</a>
</div>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>ФИО</th>
            <th>Email</th>
            <th>Роль</th>
            <th>Организация</th>
            <th>Активен</th>
            <th style="width: 220px;">Действия</th>
        </tr>
    </thead>
    <tbody>
    @if (Model.Items.Count == 0)
    {
        <tr>
            <td colspan="6" class="text-center">Пользователи не найдены</td>
        </tr>
    }
    else
    {
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.FullName</td>
                <td>@item.Email</td>
                <td>@item.Role</td>
                <td>@item.OrganizationName</td>
                <td>@(item.IsActive ? "Да" : "Нет")</td>
                <td>
                    <a asp-page="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Редактировать</a>
                </td>
            </tr>
        }
    }
    </tbody>
</table>