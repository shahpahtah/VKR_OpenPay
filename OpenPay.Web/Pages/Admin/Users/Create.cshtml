@page
@model OpenPay.Web.Pages.Admin.Users.CreateModel
@{
    ViewData["Title"] = "Новый сотрудник";
}

<div class="page-actions">
    <div>
        <h2 class="mb-1">Новый сотрудник</h2>
        <div class="text-muted">Создание пользователя текущей организации и назначение роли</div>
    </div>

    <a asp-page="Index" class="btn btn-outline-secondary">Назад к списку</a>
</div>

<div class="section-card">
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Item.FullName" class="form-label"></label>
                <input asp-for="Item.FullName" class="form-control" autocomplete="name" />
                <span asp-validation-for="Item.FullName" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Item.Email" class="form-label"></label>
                <input asp-for="Item.Email" class="form-control" autocomplete="email" />
                <span asp-validation-for="Item.Email" class="text-danger"></span>
            </div>

            <div class="col-md-4">
                <label asp-for="Item.Role" class="form-label"></label>
                <select asp-for="Item.Role" asp-items="Model.RoleOptions" class="form-select">
                    <option value="">-- выберите роль --</option>
                </select>
                <span asp-validation-for="Item.Role" class="text-danger"></span>
            </div>

            <div class="col-md-4">
                <label asp-for="Item.Password" class="form-label"></label>
                <input asp-for="Item.Password" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="Item.Password" class="text-danger"></span>
            </div>

            <div class="col-md-4">
                <label asp-for="Item.ConfirmPassword" class="form-label"></label>
                <input asp-for="Item.ConfirmPassword" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="Item.ConfirmPassword" class="text-danger"></span>
            </div>
        </div>

        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Создать сотрудника</button>
            <a asp-page="Index" class="btn btn-outline-secondary">Отмена</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
