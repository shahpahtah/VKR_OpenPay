@page
@model OpenPay.Web.Pages.Admin.Organizations.CreateModel
@{
    ViewData["Title"] = "Новая организация";
}

<div class="page-actions">
    <div>
        <h2 class="mb-1">Новая организация</h2>
        <div class="text-muted">Создание организации и первого администратора</div>
    </div>

    <a asp-page="Index" class="btn btn-outline-secondary">Назад к списку</a>
</div>

<div class="section-card">
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-3">
            <div class="col-md-12">
                <h5 class="mb-0">Реквизиты организации</h5>
            </div>

            <div class="col-md-6">
                <label asp-for="Item.Name" class="form-label"></label>
                <input asp-for="Item.Name" class="form-control" />
                <span asp-validation-for="Item.Name" class="text-danger"></span>
            </div>

            <div class="col-md-3">
                <label asp-for="Item.Inn" class="form-label"></label>
                <input asp-for="Item.Inn" class="form-control" />
                <span asp-validation-for="Item.Inn" class="text-danger"></span>
            </div>

            <div class="col-md-3">
                <label asp-for="Item.Kpp" class="form-label"></label>
                <input asp-for="Item.Kpp" class="form-control" />
                <span asp-validation-for="Item.Kpp" class="text-danger"></span>
            </div>

            <div class="col-md-12 mt-3">
                <h5 class="mb-0">Администратор организации</h5>
            </div>

            <div class="col-md-6">
                <label asp-for="Item.AdminFullName" class="form-label"></label>
                <input asp-for="Item.AdminFullName" class="form-control" autocomplete="name" />
                <span asp-validation-for="Item.AdminFullName" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Item.AdminEmail" class="form-label"></label>
                <input asp-for="Item.AdminEmail" class="form-control" autocomplete="email" />
                <span asp-validation-for="Item.AdminEmail" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Item.AdminPassword" class="form-label"></label>
                <input asp-for="Item.AdminPassword" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="Item.AdminPassword" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Item.ConfirmAdminPassword" class="form-label"></label>
                <input asp-for="Item.ConfirmAdminPassword" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="Item.ConfirmAdminPassword" class="text-danger"></span>
            </div>
        </div>

        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Создать организацию</button>
            <a asp-page="Index" class="btn btn-outline-secondary">Отмена</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
