@page
@model OpenPay.Web.Pages.Admin.BankConnections.IndexModel
@{
    ViewData["Title"] = "Банковские подключения";
}

<div class="page-actions">
    <div>
        <h2 class="mb-1">Банковские подключения</h2>
        <div class="text-muted">Демо-настройки адаптеров OpenBanking и защищенных токенов</div>
    </div>
    <a asp-page="Create" class="btn btn-primary">Добавить подключение</a>
</div>

<div class="section-card mb-4">
    <form method="get" class="d-flex align-items-center gap-3 flex-wrap">
        <div class="form-check">
            <input asp-for="ShowInactive" class="form-check-input" />
            <label asp-for="ShowInactive" class="form-check-label">Показывать неактивные</label>
        </div>
        <button type="submit" class="btn btn-outline-secondary">Применить</button>
    </form>
</div>

<div class="section-card">
    @if (Model.Items.Count == 0)
    {
        <div class="empty-state">
            <h5 class="mb-2">Подключения не настроены</h5>
            <div class="mb-3">Создайте демо-подключение, чтобы связать его со счетом организации.</div>
            <a asp-page="Create" class="btn btn-primary">Добавить подключение</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Название</th>
                        <th>Банк</th>
                        <th>Токены</th>
                        <th>Статус</th>
                        <th style="width: 220px;">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="fw-semibold">@item.DisplayName</td>
                            <td>
                                <div>@item.BankDisplayName</div>
                                <div class="text-muted small">@item.BankCode</div>
                            </td>
                            <td>
                                <span class="badge-soft @(item.HasAccessToken ? "badge-executed" : "badge-error")">Access</span>
                                <span class="badge-soft @(item.HasRefreshToken ? "badge-executed" : "badge-error")">Refresh</span>
                            </td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge-soft badge-executed">Активно</span>
                                }
                                else
                                {
                                    <span class="badge-soft badge-draft">Неактивно</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-2 flex-wrap">
                                    <a asp-page="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Изменить</a>
                                    @if (item.IsActive)
                                    {
                                        <form method="post" asp-page-handler="Deactivate" asp-route-id="@item.Id" class="m-0">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Отключить</button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
