@page
@model OpenPay.Web.Pages.Admin.ApprovalRoutes.IndexModel
@{
    ViewData["Title"] = "Маршруты согласования";
}

<div class="page-actions">
    <div>
        <h2 class="mb-1">Маршруты согласования</h2>
        <div class="text-muted">Правила подбора маршрута по сумме, типу расхода и подразделению</div>
    </div>
    <a asp-page="Create" class="btn btn-primary">Добавить маршрут</a>
</div>

<div class="section-card mb-4">
    <form method="get" class="d-flex align-items-center gap-3 flex-wrap">
        <div class="form-check">
            <input asp-for="ShowInactive" class="form-check-input" />
            <label asp-for="ShowInactive" class="form-check-label">Показывать неактивные</label>
        </div>
        <button type="submit" class="btn btn-outline-secondary">Применить</button>
    </form>
</div>

<div class="section-card">
    @if (Model.Items.Count == 0)
    {
        <div class="empty-state">
            <h5 class="mb-2">Маршруты не настроены</h5>
            <div class="mb-3">Без маршрута платежи все равно можно отправить руководителю, но правила не будут отображаться в карточке.</div>
            <a asp-page="Create" class="btn btn-primary">Добавить маршрут</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Название</th>
                        <th>Сумма</th>
                        <th>Тип расхода</th>
                        <th>Подразделение</th>
                        <th>Режим</th>
                        <th>Статус</th>
                        <th style="width: 210px;">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="fw-semibold">@item.Name</td>
                            <td>
                                @(item.MinAmount?.ToString("N2") ?? "0")
                                -
                                @(item.MaxAmount?.ToString("N2") ?? "∞")
                            </td>
                            <td>@(string.IsNullOrWhiteSpace(item.ExpenseType) ? "Любой" : item.ExpenseType)</td>
                            <td>@(string.IsNullOrWhiteSpace(item.Department) ? "Любое" : item.Department)</td>
                            <td>@UiText.ApprovalTypeText(item.ApprovalType.ToString())</td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge-soft badge-executed">Активен</span>
                                }
                                else
                                {
                                    <span class="badge-soft badge-draft">Неактивен</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-2 flex-wrap">
                                    <a asp-page="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Изменить</a>
                                    @if (item.IsActive)
                                    {
                                        <form method="post" asp-page-handler="Deactivate" asp-route-id="@item.Id" class="m-0">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Отключить</button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
